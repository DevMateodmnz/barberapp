    "@types/node": "^25.6.0",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "private": true
