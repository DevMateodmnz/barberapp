    "@react-navigation/native-stack": "^6.9.26",
    "@supabase/supabase-js": "^2.39.7",
    "date-fns": "^3.3.1",
    "expo": "~50.0.0",
    "expo-image-picker": "~14.7.1",
    "expo-notifications": "~0.27.6",
    "expo-status-bar": "~1.11.1",
    "pg": "^8.20.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.50.1",
    "react-native": "0.73.6",
    "react-native-calendars": "^1.1305.0",
